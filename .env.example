DATABASE_URL="postgresql://127.0.0.1:5432/sis_mvp_dev?schema=public"
# Set to "true" on HTTPS deployments so auth cookies use the Secure flag (local http:// dev: false)
SECURE_COOKIES=false
# Must decode to exactly 32 bytes. Generate with: openssl rand -base64 32
# WARNING: Do NOT use the all-zero placeholder. The app will refuse to start with a weak key.
PERSON_DATA_KEY_BASE64=""
PII_INDEX_KEY_BASE64=""
JWT_ACCESS_SECRET="REPLACE_WITH_UNIQUE_RANDOM_SECRET_AT_LEAST_32_CHARS"
JWT_REFRESH_SECRET="REPLACE_WITH_UNIQUE_RANDOM_SECRET_AT_LEAST_32_CHARS"
# Optional: HTTP-only session cookie lifetime in seconds (clamped between 1800 and 86400; default 28800 = 8 hours)
# SESSION_MAX_AGE_SECONDS="28800"
# Set to "1" ONLY when the app runs behind a trusted reverse proxy (nginx, AWS ALB, Cloudflare, etc.)
# that reliably overwrites x-forwarded-for. Never set this if the app is exposed directly to the internet.
# TRUST_PROXY="1"
# Optional: command template for AV scan hook (uploaded temp file path appended automatically)
# PERSON_PHOTO_AV_SCAN_COMMAND=""
# Key rotation: set this to the OLD key when rotating PERSON_DATA_KEY_BASE64, then run npm run db:reencrypt-pii
# PERSON_DATA_KEY_PREV_BASE64=""
