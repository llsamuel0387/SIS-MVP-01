{
  "name": "sis-mvp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node ./scripts/dev-runtime.mjs",
    "dev:clean": "node -e \"const fs=require('fs'); for (const d of ['.next','.next-dev','.next-e2e','.sis-dev']) { try { fs.rmSync(d,{recursive:true,force:true}); } catch (e) {} }\" && node ./scripts/dev-runtime.mjs",
    "dev:fast": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "check:repo-files": "node ./scripts/verify-required-repo-files.mjs",
    "check:mutation-audit": "node ./scripts/verify-mutation-audit.mjs",
    "test": "vitest run && vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "playwright:install": "playwright install chromium",
    "test:e2e": "playwright test",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "npm run test && npm run test:e2e",
    "db:generate": "prisma generate",
    "db:push": "node ./scripts/prisma-db-push-dev.mjs",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node ./scripts/prisma-tsx-with-dev-db.mjs prisma/seed.ts",
    "db:wipe-dev": "node ./scripts/wipe-dev-db.mjs",
    "db:backfill:person-sections": "node ./scripts/prisma-tsx-with-dev-db.mjs prisma/backfill-person-sections.ts",
    "db:backfill:pii": "node ./scripts/prisma-tsx-with-dev-db.mjs prisma/backfill-pii-encryption.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "@tailwindcss/postcss": "^4.2.2",
    "argon2": "^0.44.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.8.0",
    "next": "^15.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "redis": "^5.12.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "world-countries": "^5.1.0",
    "zod": "^4.3.6"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.15",
    "jsdom": "^29.0.2",
    "prisma": "^6.6.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.4"
  }
}
